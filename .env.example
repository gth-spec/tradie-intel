# Supabase
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Cron auth — generate a random string of at least 32 characters.
# Suggested: `openssl rand -hex 32` or `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
CRON_SECRET=

# Email provider (kit | loops | mailchimp | memory)
# `memory` is for local dev - captures emails in-memory only, no external call.
EMAIL_PROVIDER=memory
EMAIL_PROVIDER_API_KEY=
EMAIL_LIST_ID=

# Firecrawl - primary scrape adapter (src/lib/scrape.ts).
# Free tier: 500 scrapes/month. Sign up at https://firecrawl.dev
FIRECRAWL_API_KEY=

# Apify - fallback scrape adapter (src/lib/scrape-apify.ts). Only invoked when
# Firecrawl returns empty or errors. Free tier: 8GB RAM, ~$5/month credit.
# Sign up at https://apify.com
APIFY_TOKEN=
