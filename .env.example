# Supabase
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# PostHog - LLM observability ($ai_generation events for enrich()).
# Optional: if unset, enrich() falls back to the plain Anthropic SDK (no telemetry).
# Token is write-only (safe in client code). Set both in Vercel + Trigger.dev env too.
POSTHOG_API_KEY=phc_tLPihocB7MYpyfqQHPTTYnBeYSQ2McGvqn5sYcqFJ3p3
POSTHOG_HOST=https://us.i.posthog.com

# Cron auth — generate a random string of at least 32 characters.
# Suggested: `openssl rand -hex 32` or `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
CRON_SECRET=

# Email provider (kit | loops | mailchimp | memory | resend)
# `memory` is for local dev - captures emails in-memory only, no external call.
EMAIL_PROVIDER=memory
EMAIL_PROVIDER_API_KEY=
EMAIL_LIST_ID=

# Resend (digest broadcast send + subscribe form contact create)
RESEND_API_KEY=re_xxx
RESEND_SEGMENT_ID=0dfd2746-a869-4ea0-93b3-2b308fe32b2e
RESEND_FROM="TradieIntel <hello@tradieintel.com.au>"

# Digest approval flow
DIGEST_APPROVER_EMAIL=hello@tradieintel.com.au
PUBLIC_SITE_URL=https://tradieintel.com.au

# Firecrawl - primary scrape adapter (src/lib/scrape.ts).
# Free tier: 500 scrapes/month. Sign up at https://firecrawl.dev
FIRECRAWL_API_KEY=

# Apify - fallback scrape adapter (src/lib/scrape-apify.ts). Only invoked when
# Firecrawl returns empty or errors. Free tier: 8GB RAM, ~$5/month credit.
# Sign up at https://apify.com
APIFY_TOKEN=

# AgentMail - QA inbox for digest approval flow.
# API key is in ~/.zshrc as AGENTMAIL_API_KEY. Add to Vercel env vars before first live run.
AGENTMAIL_API_KEY=
