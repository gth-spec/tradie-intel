# Tradie Intel - local environment template
# Copy to .env (NOT committed to git) and fill in the FILL_ME values.
# This file is committed only as a template - real .env is gitignored.

# ── Supabase (new naming model: publishable/secret) ───────────────────
# From Supabase Dashboard → Project Settings → API Keys
#   Publishable key: starts with sb_publishable_  (safe for browser)
#   Secret key:      starts with sb_secret_       (server-only, treat as password)
SUPABASE_URL=FILL_ME_https://xxxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=FILL_ME_sb_publishable_...
SUPABASE_SECRET_KEY=FILL_ME_sb_secret_...

# ── Anthropic ────────────────────────────────────────────────────────
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=FILL_ME_sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ── Cron auth ───────────────────────────────────────────────────────
# Generate a 32-byte hex string. Treat as a password (never commit).
#   openssl rand -hex 32
CRON_SECRET=FILL_ME_64_hex_chars

# ── Email provider (dev: memory; lock real provider before launch) ──
EMAIL_PROVIDER=memory
EMAIL_PROVIDER_API_KEY=
EMAIL_LIST_ID=
